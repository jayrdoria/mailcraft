{
  "name": "mailcraft",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --env-file .env.development",
    "db:push": "prisma db push --env-file .env.development",
    "db:seed": "tsx --env-file .env.development prisma/seed.ts",
    "db:studio": "dotenv -e .env.development -- prisma studio"
  },
  "prisma": {
    "seed": "tsx --env-file .env.development prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@gsap/react": "^2.1.1",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.12.5",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.469.0",
    "next": "^15.2.0",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.2.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
