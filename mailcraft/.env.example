# ══════════════════════════════════════════════════════
# MailCraft — Environment Variables
# Copy this to .env and fill in all values before running
# NEVER commit .env to git
# ══════════════════════════════════════════════════════

# ──────────────────────────────────────
# App
# ──────────────────────────────────────
NODE_ENV=production           # development | production
BUILD_TARGET=runner           # dev (hot-reload) | runner (production build)
APP_PORT=7070                 # 3000 for dev, 7070 for prod

# Generate with: openssl rand -base64 32
# Required — signs JWT session cookies. Must never change in prod (logs everyone out).
NEXTAUTH_SECRET=

# Full URL where the app is publicly accessible (no trailing slash)
# Local dev:  http://localhost:3000
# Production: https://employee.netovation.eu/mailcraft
NEXTAUTH_URL=

# ──────────────────────────────────────
# Database — PostgreSQL
# ──────────────────────────────────────
# These 3 are used by the postgres Docker container to create the DB on first run.
# You choose these values — just make POSTGRES_PASSWORD strong.
POSTGRES_USER=mailcraft_user
POSTGRES_PASSWORD=
POSTGRES_DB=mailcraft_db

# Must match the values above exactly.
# In Docker Compose, the host is "postgres" (the service name), NOT "localhost".
DATABASE_URL=postgresql://mailcraft_user:SAME_AS_POSTGRES_PASSWORD@postgres:5432/mailcraft_db

# ──────────────────────────────────────
# Redis
# ──────────────────────────────────────
# In Docker Compose, host is "redis" (the service name).
REDIS_URL=redis://redis:6379

# ──────────────────────────────────────
# Template file storage
# ──────────────────────────────────────
# Where master + saved template HTML files are stored on the server filesystem.
# Must be an absolute path that the Docker container can access (mounted as a volume).
#
# Production path (VPS):
# TEMPLATE_BASE_DIR=/home/admin/mailcraft-data
#
# Local dev (relative to project):
# TEMPLATE_BASE_DIR=./data/templates
TEMPLATE_BASE_DIR=

# Next.js basePath prefix — must match next.config.ts basePath
NEXT_PUBLIC_BASE_PATH=/mailcraft

# ──────────────────────────────────────
# Seed passwords — initial setup only
# Delete these 3 lines from .env after running: npm run db:seed
# ──────────────────────────────────────
SEED_ADMIN_PASSWORD=
SEED_CRM_PASSWORD=
SEED_VIP_PASSWORD=
